---
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../i18n/utils';
import NavigationIsland from './islands/Navigation.tsx';

interface Props {
	path?: string;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const navItems = [
	{ href: translatePath('/#home'), label: t('nav.home') },
	{ href: translatePath('/#photos'), label: t('nav.photos') },
	{ href: translatePath('/#contact'), label: t('nav.contact') }
];
---

<NavigationIsland client:load navItems={navItems} menuLabel={t('nav.menu')} />
