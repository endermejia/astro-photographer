---
import { photos } from '../utils/photos.mjs';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import AlbumLightbox from './islands/AlbumLightbox.tsx';
import 'keen-slider/keen-slider.min.css';

interface Props {
	album: string;
}

const { album } = Astro.props;
const albumsData = photos('assets/img/albums');
const pics = albumsData[album]?.images || [];
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const translations = {
	title: t('photos.title'),
	climbing: t('photos.climbing'),
	people: t('photos.people'),
	events: t('photos.events'),
	business: t('photos.business'),
	travel: t('photos.travel')
};
---

<AlbumLightbox client:load photos={pics} lang={lang} translations={translations} albumName={album} />
