{
	"name": "nhoanoir.com",
	"type": "module",
	"version": "1.0.0",
	"private": true,
	"description": "Nhoa Noir | Fotografía",
	"keywords": [
		"website",
		"fotografía",
		"photography"
	],
	"homepage": "https://nhoanoir.com",
	"engines": {
		"node": ">=16.0.0",
		"npm": ">=8.0.0"
	},
	"devDependencies": {
		"@babel/core": "^8.0.1",
		"@babel/preset-env": "^8.0.2",
		"@commitlint/cli": "^21.1.0",
		"@commitlint/config-conventional": "^21.1.0",
		"@csstools/postcss-oklab-function": "^5.0.5",
		"@eslint/eslintrc": "^3.3.5",
		"@eslint/js": "^10.0.1",
		"@hint/formatter-codeframe": "^3.1.36",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/git": "^10.0.1",
		"@typescript-eslint/eslint-plugin": "^8.62.0",
		"@typescript-eslint/parser": "^8.62.0",
		"autoprefixer": "^10.5.2",
		"babel-loader": "^10.1.1",
		"browserslist": "^4.28.4",
		"concurrently": "^10.0.3",
		"cssnano": "^8.0.2",
		"cssremedy": "^0.1.0-beta.2",
		"eslint": "^10.5.0",
		"eslint-plugin-compat": "^7.0.2",
		"globals": "^17.7.0",
		"hint": "^7.1.13",
		"husky": "^9.1.7",
		"image-size": "^2.0.2",
		"postcss": "^8.5.15",
		"postcss-loader": "^8.2.1",
		"postcss-nesting": "^14.0.0",
		"postcss-preset-env": "^11.3.1",
		"prettier": "^3.8.5",
		"semantic-release": "^25.0.5",
		"sharp": "^0.35.2",
		"stylelint": "^17.14.0",
		"stylelint-config-property-sort-order-smacss": "^11.2.0",
		"stylelint-config-standard": "^40.0.0",
		"stylelint-order": "^8.1.1",
		"stylelint-use-logical-spec": "^5.0.1",
		"typescript": "^6.0.3",
		"vite": "^8.1.0",
		"wait-on": "^9.0.10"
	},
	"optionalDependencies": {
		"lint-staged": "^17.0.8"
	},
	"scripts": {
		"start": "astro dev",
		"start:prod": "astro preview",
		"build": "astro build",
		"build:img": "node src/utils/sharp.cjs",
		"lint": "concurrently 'npm:lint:*(!fix)'",
		"lint:fix": "concurrently -m 1 'npm:lint:*:fix'",
		"lint:js": "eslint \"src/**/*.{js,mjs,cjs,ts}\" --no-error-on-unmatched-pattern",
		"lint:js:fix": "eslint \"src/**/*.{js,mjs,cjs,ts}\" --no-error-on-unmatched-pattern --fix",
		"lint:css": "stylelint \"src/**/*.{css,less,sass,scss}\" --aei --ignore-path .gitignore",
		"lint:css:fix": "stylelint \"src/**/*.{css,less,sass,scss}\" --aei --ignore-path .gitignore --fix",
		"lint:style": "prettier --check --ignore-unknown .",
		"lint:style:fix": "prettier --write --ignore-unknown .",
		"hint": "wait-on -t 300000 http://localhost:4321/ && hint http://localhost:4321/",
		"test": "concurrently 'npm:test:*'",
		"test:hint": "concurrently \"npm:start:prod\" \"npm:hint\" --kill-others  --s first"
	},
	"dependencies": {
		"@astrojs/sitemap": "^3.7.3",
		"@fontsource/cinzel": "^5.2.8",
		"@fontsource/playfair-display": "^5.2.8",
		"@fontsource/raleway": "^5.2.8",
		"@fontsource/titillium-web": "^5.2.8",
		"astro": "^7.0.3"
	}
}
